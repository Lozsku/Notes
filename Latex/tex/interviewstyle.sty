\definecolor{zebra}{HTML}{f3f5fb}
\setlength{\arrayrulewidth}{0.6pt}
\renewcommand{\arraystretch}{1.28}
\arrayrulecolor{rule}
\AtBeginEnvironment{longtable}{\small}
