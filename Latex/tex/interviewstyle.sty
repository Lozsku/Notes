\newcommand{\heademph}[1]{{\headingfont\bfseries\color{ink}#1}}

% =====================================================================
%  TITLE PAGE
% =====================================================================
\newcommand{\makecoverpage}{%
  \begin{titlepage}
  \thispagestyle{empty}
  \newgeometry{margin=0pt}
  \begin{tikzpicture}[remember picture,overlay]
    \fill[ink] (current page.south west) rectangle (current page.north east);
    \fill[acc] (current page.north west) rectangle ([yshift=-5.2cm]current page.north east);
    \fill[acc2,opacity=0.35] ([yshift=-4.6cm]current page.north west)
        -- ([yshift=-5.2cm]current page.north east)
        -- ([yshift=-5.9cm]current page.north east)
        -- ([yshift=-5.3cm]current page.north west) -- cycle;
    % kicker
    \node[anchor=north west,text=white,font=\headingfont\bfseries\large,xshift=2cm,yshift=-1.6cm]
      at (current page.north west) {\ThemeKicker};
    \node[anchor=north west,text=white,opacity=0.85,font=\headingfont\small,xshift=2cm,yshift=-2.5cm]
      at (current page.north west) {Interview Preparation Series \textbullet\ Professional Edition};
    % big title
    \node[anchor=west,text=white,font=\headingfont\fontsize{34}{38}\selectfont\bfseries,
          text width=17cm,align=left,xshift=2cm,yshift=-9.2cm]
      at (current page.north west) {\hyphenpenalty=10000\exhyphenpenalty=10000\RaggedRight\ThemeName};
    \ifx\ThemeNumber\empty\else
      \node[anchor=west,text=acc2,font=\headingfont\fontsize{120}{120}\selectfont\bfseries,
            opacity=0.16,xshift=11.5cm,yshift=-15cm] at (current page.north west) {\ThemeNumber};
    \fi
    % footer strip
    \node[anchor=south west,text=white,opacity=0.7,font=\headingfont\footnotesize,xshift=2cm,yshift=1.5cm]
      at (current page.south west) {Compiled with \LaTeX\ \textbullet\ \today};
    \node[anchor=south east,text=acc2,font=\headingfont\footnotesize\bfseries,xshift=-2cm,yshift=1.5cm]
      at (current page.south east) {harsha.somisetty01@gmail.com};
  \end{tikzpicture}
  \restoregeometry
  \end{titlepage}
}
